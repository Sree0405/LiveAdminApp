{
  "expo": {
    "name": "LifeAdminPro",
    "slug": "live-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image/app-logo.png",
    "scheme": "lifeadminpro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sreekanthdevsorganization.liveadmin",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/image/app-logo.png",
        "backgroundImage": "./assets/image/app-logo.png",
        "monochromeImage": "./assets/image/app-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sreekanthdevsorganization.liveadmin"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/image/app-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/image/app-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F8FA",
          "dark": {
            "backgroundColor": "#09090B"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/image/app-logo.png"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1d72e00-1807-47f1-9161-d001cba8cade"
      }
    },
    "owner": "sreekanth-devs-organization"
  }
}
